# ═══════════════════════════════════════════════════════
#  Crush Bot — Environment Variables
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (admin)
ADMIN_ID=123456789

# Public URL of your deployed app (Railway/Render/etc)
BASE_URL=https://your-app.up.railway.app

# Secret for admin web panel access
ADMIN_SECRET=your_secret_here

# Set to true for production (webhook), false for local (polling)
WEBHOOK_MODE=false

# Firebase — Option 1: Full JSON (paste entire service account JSON)
FIREBASE_CREDENTIALS_JSON=

# Firebase — Option 2: Individual values
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CERT_URL=
